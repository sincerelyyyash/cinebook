{
  "name": "cinebook-backend",
  "version": "0.1.0",
  "description": "CineBook — AI-powered movie booking platform (backend)",
  "type": "module",
  "module": "src/server.ts",
  "private": true,
  "scripts": {
    "dev": "bun run --watch src/server.ts",
    "dev:worker": "bun run --watch src/worker.ts",
    "start": "bun run src/server.ts",
    "start:worker": "bun run src/worker.ts",
    "build": "bun build src/server.ts --target=bun --outdir dist",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "bun test",
    "test:unit": "bun test tests/unit",
    "test:integration": "bun test tests/integration",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "db:seed": "bun run prisma/seed.ts",
    "db:posters": "bun run scripts/backfill-posters.ts",
    "db:reset": "prisma migrate reset --force"
  },
  "prisma": {
    "seed": "bun run prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.2.1",
    "better-auth": "^1.6.23",
    "bullmq": "^5.34.6",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "ioredis": "5.10.1",
    "jsonwebtoken": "^9.0.2",
    "nanoid": "^5.0.9",
    "pino": "^9.6.0",
    "pino-http": "^10.4.0",
    "prom-client": "^15.1.3",
    "rate-limiter-flexible": "^5.0.4",
    "ws": "^8.21.0",
    "zod": "^3.24.1",
    "zod-to-json-schema": "^3.24.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.5",
    "@types/ws": "^8.18.1",
    "bun-types": "^1.3.14",
    "eslint": "^9.17.0",
    "pino-pretty": "^13.0.0",
    "prettier": "^3.4.2",
    "prisma": "^6.2.1",
    "typescript": "^5.7.3"
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "overrides": {
    "ioredis": "5.10.1"
  }
}
