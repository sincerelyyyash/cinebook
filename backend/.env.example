# ─────────────────────────────────────────────────────────────
# CineBook Backend — environment variables
# Copy to `.env` and fill in. `src/config/env.ts` validates these at boot.
# ─────────────────────────────────────────────────────────────

# Runtime
NODE_ENV=development
PORT=4000
LOG_LEVEL=debug                 # trace | debug | info | warn | error

# Database (Postgres) — matches docker-compose defaults
DATABASE_URL=postgresql://cinebook:cinebook@localhost:5432/cinebook?schema=public

# Redis (cache + BullMQ) — matches docker-compose defaults
REDIS_URL=redis://localhost:6379

# Auth / JWT
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-long
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars-long
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# OTP (simulated phone verification)
OTP_TTL_SECONDS=300
OTP_LENGTH=6
# In non-production, OTP codes are returned in the API response / logs for testing.
OTP_DEV_ECHO=true

# LLM gateway (OpenRouter — OpenAI-compatible)
OPENROUTER_API_KEY=sk-or-your-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=anthropic/claude-sonnet-4.5
OPENROUTER_APP_URL=http://localhost:4000
OPENROUTER_APP_NAME=CineBook

# CORS (comma-separated origins; * for all in dev)
CORS_ORIGINS=*
