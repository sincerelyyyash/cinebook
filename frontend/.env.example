# ── CineBook Web — environment ──────────────────────────────────────────────
# Server-side base URL for the backend API (used by RSC fetch + BFF proxy).
API_BASE_URL=http://localhost:4000

# Public base URL exposed to the browser (client SWR + WS/SSE).
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

# WebSocket origin for live seat availability (defaults to API base with ws:// scheme).
NEXT_PUBLIC_WS_URL=ws://localhost:4000

# App name shown in the shell / metadata.
NEXT_PUBLIC_APP_NAME=CineBook

# Dev-only: preview the shells with a mock user (no backend needed). Set to 1
# during frontend scaffolding; turn OFF (0/unset) once real auth is wired.
NEXT_PUBLIC_DEV_FAKE_AUTH=1
